generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SourcingSettings {
  id                     String   @id @default(cuid())
  currencyCode           String   @default("XOF")
  airRatePerKgFcfa       Int
  airEstimatedDays       String
  seaRealCostPerCbmFcfa  Int
  seaSellRatePerCbmFcfa  Int
  seaEstimatedDays       String
  freeAirThresholdFcfa   Int
  freeAirEnabled         Boolean  @default(true)
  airWeightThresholdKg   Decimal  @db.Decimal(10, 3)
  containerTargetCbm     Decimal  @db.Decimal(10, 4)
  defaultMarginMode      String
  defaultMarginValue     Decimal  @db.Decimal(12, 2)
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
}

model SourcingSeaContainer {
  id               String          @id @default(cuid())
  code             String          @unique
  targetCbm        Decimal         @db.Decimal(10, 4)
  currentCbm       Decimal         @db.Decimal(10, 4)
  fillPercent      Int
  status           String
  orderCount       Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  readyToShipAt    DateTime?
  shipmentTriggeredAt DateTime?
  orders           SourcingOrder[]
}

model SourcingOrder {
  id                    String                  @id @default(cuid())
  orderNumber           String                  @unique
  userId                String?
  customerAddressId     String?
  customerName          String
  customerEmail         String
  customerPhone         String
  addressLine1          String
  addressLine2          String?
  city                  String
  state                 String
  postalCode            String?
  countryCode           String
  shippingMethod        String
  shippingCostFcfa      Int
  cartProductsTotalFcfa Int
  totalPriceFcfa        Int
  totalWeightKg         Decimal                 @db.Decimal(10, 3)
  totalVolumeCbm        Decimal                 @db.Decimal(10, 4)
  status                String
  freightStatus         String
  supplierOrderStatus   String
  paymentStatus         String                  @default("unpaid")
  paymentProvider       String?
  paymentCurrency       String                  @default("XOF")
  alibabaTradeIds       Json?
  freightPayload        Json?
  supplierOrderPayload  Json?
  monerooPaymentId      String?                 @unique
  monerooCheckoutUrl    String?
  monerooPaymentStatus  String?
  monerooPaymentPayload Json?
  monerooInitializedAt  DateTime?
  monerooVerifiedAt     DateTime?
  paidAt                DateTime?
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  containerId           String?
  user                  User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  customerAddress       CustomerAddress?        @relation(fields: [customerAddressId], references: [id], onDelete: SetNull)
  container             SourcingSeaContainer?   @relation(fields: [containerId], references: [id])
  items                 SourcingOrderItem[]
  integrationLogs       AlibabaIntegrationLog[]
  remittanceProofs      OrderRemittanceProof[]

  @@index([createdAt])
  @@index([status])
  @@index([shippingMethod])
  @@index([paymentStatus])
  @@index([userId])
  @@index([customerAddressId])
}

model SourcingOrderItem {
  id                 String        @id @default(cuid())
  orderId            String
  order              SourcingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productSlug        String
  productName        String
  quantity           Int
  supplierPriceFcfa  Int
  marginMode         String
  marginValue        Decimal       @db.Decimal(12, 2)
  marginAmountFcfa   Int
  finalUnitPriceFcfa Int
  finalLinePriceFcfa Int
  weightKg           Decimal       @db.Decimal(10, 3)
  volumeCbm          Decimal       @db.Decimal(10, 4)
  image              String
}

model AlibabaIntegrationLog {
  id           String         @id @default(cuid())
  orderId      String?
  order        SourcingOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  action       String
  endpoint     String
  status       String
  requestBody  Json?
  responseBody Json?
  createdAt    DateTime       @default(now())

  @@index([createdAt])
  @@index([status])
}

model AlibabaSupplierAccountRecord {
  id                    String   @id
  name                  String
  email                 String
  accountPlatform       String
  countryCode           String
  defaultDispatchLocation String
  status                String
  memberId              String?
  resourceOwner         String?
  appKey                String?
  appSecret             Json?
  authorizeUrl          String?
  tokenUrl              String?
  refreshUrl            String?
  apiBaseUrl            String?
  accessToken           Json?
  refreshToken          Json?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  accountId             String?
  accountLogin          String?
  accountName           String?
  oauthCountry          String?
  isActive              Boolean  @default(false)
  hasAppSecret          Boolean  @default(false)
  hasAccessToken        Boolean  @default(false)
  hasRefreshToken       Boolean  @default(false)
  lastAuthorizedAt      DateTime?
  lastError             String?
  accessTokenHint       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isActive, status])
  @@index([status])
  @@index([updatedAt])
}

model AlibabaImportJobRecord {
  id                 String   @id
  query              String
  limit              Int
  fulfillmentChannel String
  autoPublish        Boolean  @default(false)
  status             String
  importedCount      Int      @default(0)
  errorMessage       String?
  productIds         Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([updatedAt])
}

model AlibabaImportedProductRecord {
  id                String   @id
  sourceProductId   String
  categorySlug      String?
  categoryTitle     String?
  categoryPath      Json?
  slug              String   @unique
  title             String
  shortTitle        String
  description       String
  query             String
  keywords          Json
  image             String
  gallery           Json
  videoUrl          String?
  videoPoster       String?
  packaging         String
  itemWeightGrams   Int
  lotCbm            String
  minUsd            Float
  maxUsd            Float?
  moq               Int
  unit              String
  badge             String?
  supplierName      String
  supplierLocation  String
  supplierCompanyId String?
  responseTime      String
  yearsInBusiness   Int
  transactionsLabel String
  soldLabel         String
  customizationLabel String
  shippingLabel     String
  overview          Json
  variantGroups     Json
  tiers             Json
  specs             Json
  inventory         Int
  status            String
  publishedToSite   Boolean  @default(false)
  publishedAt       DateTime?
  rawPayload        Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([publishedToSite])
  @@index([updatedAt])
}

model AlibabaCountryProfileRecord {
  countryCode         String  @id
  countryName         String
  currencyCode        String
  defaultCarrierCode  String
  importTaxRate       Float
  customsMode         String
  clearanceCodeLabel  String
  enabled             Boolean @default(true)
}

model AlibabaReceptionAddressRecord {
  id                    String   @id
  label                 String
  contactName           String
  phone                 String
  email                 String
  addressLine1          String
  addressLine2          String?
  city                  String
  state                 String
  postalCode            String?
  countryCode           String
  port                  String?
  portCode              String?
  isDefault             Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isDefault])
  @@index([updatedAt])
}

model AlibabaPurchaseOrderRecord {
  id                    String   @id
  sourceImportedProductId String
  sourceProductId       String
  productTitle          String
  supplierName          String
  supplierCompanyId     String?
  quantity              Int
  shippingAddressId     String
  logisticsPayload      Json
  buyNowPayload         Json
  freightStatus         String
  orderStatus           String
  paymentStatus         String
  tradeId               String?
  payUrl                String?
  payFailureReason      String?
  amountUsd             Float
  rawFreightResponse    Json?
  rawOrderResponse      Json?
  rawPaymentResponse    Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([updatedAt])
}

model AlibabaReceptionRecordItem {
  id               String   @id
  purchaseOrderId  String
  productTitle     String
  quantityExpected Int
  quantityReceived Int
  status           String
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([purchaseOrderId])
  @@index([status])
  @@index([updatedAt])
}

model User {
  id                   String                @id @default(cuid())
  clerkUserId          String?               @unique
  email                String                @unique
  displayName          String
  firstName            String
  passwordHash         String?
  passwordSalt         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  addresses            CustomerAddress[]
  favorites            Favorite[]
  quoteRequests        QuoteRequest[]
  supportConversations SupportConversation[]
  sourcingOrders       SourcingOrder[]
  sharedCartLinks      SharedCartLink[]
}

model CustomerAddress {
  id            String          @id @default(cuid())
  userId        String
  label         String
  recipientName String
  phone         String
  email         String?
  addressLine1  String
  addressLine2  String?
  city          String
  state         String
  postalCode    String?
  countryCode   String
  isDefault     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders        SourcingOrder[]

  @@index([userId, createdAt])
  @@index([userId, isDefault])
}

model Favorite {
  id          String   @id @default(cuid())
  userId      String
  productSlug String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productSlug])
  @@index([productSlug])
}

model QuoteRequest {
  id             String   @id @default(cuid())
  userId         String
  productName    String
  quantity       String
  specifications String
  budget         String
  shippingWindow String
  notes          String?
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model SupportConversation {
  id        String           @id @default(cuid())
  userId    String
  tab       String
  name      String
  email     String?
  role      String
  preview   String
  time      String
  status    String
  aiEnabled Boolean          @default(false)
  orderId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportMessage[]

  @@index([userId, updatedAt])
  @@index([orderId])
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  side           String
  text           String
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model OrderRemittanceProof {
  id            String        @id @default(cuid())
  orderId       String
  userId        String
  amountLabel   String
  transferDate  String
  bankName      String
  bankReference String
  comment       String?
  fileName      String?
  fileType      String?
  fileSize      Int?
  status        String        @default("submitted")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  order         SourcingOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([userId, createdAt])
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  label           String
  description     String?
  amountType      String
  amountValue     Int
  minOrderFcfa    Int      @default(0)
  maxDiscountFcfa Int?
  active          Boolean  @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  usageLimit      Int?
  usageCount      Int      @default(0)
  usedOrderIds    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active, startsAt, endsAt])
}

model SharedCartLink {
  id                   String   @id @default(cuid())
  token                String   @unique
  ownerUserId          String
  ownerEmail           String
  ownerDisplayName     String
  message              String?
  itemsPayload         Json
  status               String
  claimCount           Int      @default(0)
  lastClaimedAt        DateTime?
  claimedByUserId      String?
  claimedByDisplayName String?
  claimedOrderId       String?
  expiresAt            DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  owner                User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
  @@index([status, expiresAt])
}